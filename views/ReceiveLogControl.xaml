<UserControl x:Class="AquaVectorUI.views.ReceiveLogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Border Style="{StaticResource PanelBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="▸ 수신 로그" Style="{StaticResource SectionTitle}"/>
            <ListBox Grid.Row="1" x:Name="LogList"
                     ItemsSource="{Binding Logs}"
                     Background="#060d14" Foreground="#00cc66"
                     FontFamily="Consolas" FontSize="10"
                     BorderThickness="0" Padding="6,4" Margin="6,0,6,6"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
        </Grid>
    </Border>
</UserControl>
