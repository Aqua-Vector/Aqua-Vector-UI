<UserControl x:Class="AquaVectorUI.views.SystemStatusPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorder}" Padding="0,4,0,8">
        <StackPanel>
            <TextBlock Text="▸ 시스템 상태" Style="{StaticResource SectionTitle}"/>

            <!-- Connection -->
            <Grid Margin="8,2,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="통신" Style="{StaticResource FieldLabel}"/>
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                            <Setter Property="Background" Value="#3a1010"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                    <Setter Property="Background" Value="#0a3020"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding ConnectionStatusText}" FontFamily="Consolas" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#ff6666"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Foreground" Value="#00ff88"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Torpedo -->
            <Grid Margin="8,2,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="어뢰" Style="{StaticResource FieldLabel}"/>
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                            <Setter Property="Background" Value="#3a1010"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTorpedoOnline}" Value="True">
                                    <Setter Property="Background" Value="#0a3020"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding TorpedoStatusText}" FontFamily="Consolas" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#ff6666"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTorpedoOnline}" Value="True">
                                        <Setter Property="Foreground" Value="#00ff88"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Door -->
            <Grid Margin="8,2,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="도어" Style="{StaticResource FieldLabel}"/>
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                            <Setter Property="Background" Value="#3a2000"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDoorOpen}" Value="True">
                                    <Setter Property="Background" Value="#0a3020"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding DoorStatusText}" FontFamily="Consolas" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#ffaa44"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDoorOpen}" Value="True">
                                        <Setter Property="Foreground" Value="#00ff88"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>

            <!-- Armed -->
            <Grid Margin="8,2,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="52"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="무장" Style="{StaticResource FieldLabel}"/>
                <Border Grid.Column="1">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusPill}">
                            <Setter Property="Background" Value="#3a1010"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsArmed}" Value="True">
                                    <Setter Property="Background" Value="#2a0808"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock FontFamily="Consolas" FontSize="10">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="SAFE"/>
                                <Setter Property="Foreground" Value="#66aaff"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsArmed}" Value="True">
                                        <Setter Property="Text" Value="ARMED"/>
                                        <Setter Property="Foreground" Value="#ff4444"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
