<UserControl x:Class="AquaVectorUI.views.GlobalMapControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Map header -->
        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="0,4,0,4" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="▸ 전역 맵  (±125m)"
                           Style="{StaticResource SectionTitle}" Margin="8,0,16,0"/>

                <!-- Legend -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#00ff88" Margin="0,0,3,0"/>
                    <TextBlock Text="어뢰"   Foreground="#a0b8cc" FontFamily="Consolas" FontSize="10" Margin="0,0,12,0"/>
                    <Path Data="M5,0 L10,9 L0,9 Z" Fill="#ff3333" Width="9" Height="9" Stretch="Fill" Margin="0,0,3,0"/>
                    <TextBlock Text="목표"   Foreground="#a0b8cc" FontFamily="Consolas" FontSize="10" Margin="0,0,12,0"/>
                    <Rectangle Width="8" Height="8" Fill="#ffaa00" Margin="0,0,3,0"/>
                    <TextBlock Text="장애물" Foreground="#a0b8cc" FontFamily="Consolas" FontSize="10" Margin="0,0,12,0"/>
                    <TextBlock Text="+" Foreground="#44aaff" FontFamily="Consolas" FontSize="14" Margin="0,0,3,0" VerticalAlignment="Center"/>
                    <TextBlock Text="선택"   Foreground="#a0b8cc" FontFamily="Consolas" FontSize="10"/>
                </StackPanel>

                <!-- Coordinate display -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <TextBlock Text="선택: " Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding SelectedCoordText}" Foreground="#44aaff"
                               FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock Text="  커서: " Style="{StaticResource FieldLabel}" Margin="10,0,4,0"/>
                    <TextBlock Text="{Binding HoverCoordText}" Foreground="#558888"
                               FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" MinWidth="80"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Map canvas -->
        <Border Grid.Row="1" Background="Black" CornerRadius="4" BorderBrush="#1e3050" BorderThickness="1">
            <Viewbox Stretch="Uniform" Margin="8">
                <Canvas x:Name="MapCanvas" Width="500" Height="500"
                        
                        MouseLeftButtonDown="MapCanvas_MouseDown"
                        MouseMove="MapCanvas_MouseMove">

                    <Rectangle Width="500" Height="500" Fill="#04080f"/>

                    <!-- Grid lines (vertical) -->
                    <Line X1="50"  Y1="0" X2="50"  Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="100" Y1="0" X2="100" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="150" Y1="0" X2="150" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="200" Y1="0" X2="200" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="250" Y1="0" X2="250" Y2="500" Stroke="#0d3a0d" StrokeThickness="1"   Opacity="0.9"/>
                    <Line X1="300" Y1="0" X2="300" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="350" Y1="0" X2="350" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="400" Y1="0" X2="400" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="450" Y1="0" X2="450" Y2="500" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>

                    <!-- Grid lines (horizontal) -->
                    <Line X1="0" Y1="50"  X2="500" Y2="50"  Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="100" X2="500" Y2="100" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="150" X2="500" Y2="150" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="200" X2="500" Y2="200" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="250" X2="500" Y2="250" Stroke="#0d3a0d" StrokeThickness="1"   Opacity="0.9"/>
                    <Line X1="0" Y1="300" X2="500" Y2="300" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="350" X2="500" Y2="350" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="400" X2="500" Y2="400" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>
                    <Line X1="0" Y1="450" X2="500" Y2="450" Stroke="#0a2a0a" StrokeThickness="0.6" Opacity="0.8"/>

                    <!-- Axis labels -->
                    <TextBlock Text="+125m" Canvas.Left="242" Canvas.Top="2"   Foreground="#1a4a1a" FontFamily="Consolas" FontSize="8"/>
                    <TextBlock Text="-125m" Canvas.Left="242" Canvas.Top="488" Foreground="#1a4a1a" FontFamily="Consolas" FontSize="8"/>
                    <TextBlock Text="-125m" Canvas.Left="2"   Canvas.Top="243" Foreground="#1a4a1a" FontFamily="Consolas" FontSize="8"/>
                    <TextBlock Text="+125m" Canvas.Left="465" Canvas.Top="243" Foreground="#1a4a1a" FontFamily="Consolas" FontSize="8"/>

                    <!-- Origin crosshair -->
                    <Line X1="240" Y1="250" X2="260" Y2="250" Stroke="#1a5a1a" StrokeThickness="1.5"/>
                    <Line X1="250" Y1="240" X2="250" Y2="260" Stroke="#1a5a1a" StrokeThickness="1.5"/>

                    <!-- Compass -->
                    <TextBlock Text="N" Canvas.Left="474" Canvas.Top="12"
                               Foreground="#cccccc" FontFamily="Consolas" FontSize="13" FontWeight="Bold"/>
                    <Polygon Points="480,10 477,24 480,22 483,24" Fill="#cccccc" Opacity="0.85"/>

                    <!-- Dynamic obstacle layer -->
                    <Canvas x:Name="ObstacleCanvas" Width="500" Height="500"/>

                    <!-- Path polyline -->
                    <Polyline x:Name="PathPolyline" Stroke="#ffaa00" StrokeThickness="1.5"
                              StrokeDashArray="4 3" Opacity="0.75"/>

                    <!-- Aim line (torpedo → selected point) -->
                    <Line x:Name="AimLine" Stroke="#4488ff" StrokeThickness="1"
                          StrokeDashArray="5 4" Opacity="0"
                          X1="250" Y1="410" X2="250" Y2="250"/>

                    <!-- Target marker -->
                    <Canvas x:Name="TargetCanvas">
                        <Polygon x:Name="TargetMarker" Points="10,0 20,18 0,18"
                                 Fill="#cc1111" Stroke="#ff5555" StrokeThickness="1.5" Opacity="0.9"/>
                        <TextBlock x:Name="TargetLabel" Text="TGT"
                                   Foreground="#ff8888" FontFamily="Consolas" FontSize="9"/>
                    </Canvas>

                    <!-- Selected point crosshair -->
                    <Canvas x:Name="SelectedCanvas" Visibility="Hidden">
                        <Line X1="-7" Y1="0" X2="7" Y2="0"  Stroke="#44aaff" StrokeThickness="1.5"/>
                        <Line X1="0"  Y1="-7" X2="0" Y2="7" Stroke="#44aaff" StrokeThickness="1.5"/>
                        <Ellipse Width="14" Height="14" Stroke="#44aaff" StrokeThickness="1"
                                 Fill="Transparent" Canvas.Left="-7" Canvas.Top="-7"/>
                    </Canvas>

                    <!-- Torpedo marker -->
                    <Canvas x:Name="TorpedoCanvas">
                        <Ellipse x:Name="TorpedoMarker" Width="14" Height="14"
                                 Fill="#00ff88" Stroke="#00aa66" StrokeThickness="1.5"/>
                        <Line x:Name="TorpedoHeadingLine" Stroke="#00ff88" StrokeThickness="2"
                              X1="7" Y1="7" X2="7" Y2="-15"/>
                        <Polygon x:Name="TorpedoArrow" Fill="#00ff88"/>
                        <TextBlock x:Name="TorpedoLabel" Text="TRP"
                                   Foreground="#88ffcc" FontFamily="Consolas" FontSize="9"/>
                    </Canvas>

                </Canvas>
            </Viewbox>
        </Border>
    </Grid>
</UserControl>
