<UserControl x:Class="AquaVectorUI.views.PathControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource PanelBorder}" Padding="0,4,0,8">
        <StackPanel>
            <TextBlock Text="▸ 경로 기록 / 재생" Style="{StaticResource SectionTitle}"/>

            <Grid Margin="8,2,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="상태: " Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1" Text="{Binding PathStatusText}"
                           Foreground="#c5a61b" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="8,0,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="기록 수: " Style="{StaticResource FieldLabel}"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding PathPointCount, StringFormat='{}{0}점'}"
                           Foreground="#c5a61b" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center"/>
            </Grid>

            <Grid Margin="8,0,8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Grid.Column="0" Grid.Row="0" Content="▶ 기록 시작" Height="24" Margin="0,0,3,4"
                        Command="{Binding StartRecordingCommand}" Style="{StaticResource SimButton}"/>
                <Button Grid.Column="1" Grid.Row="0" Content="⏹ 기록 중지" Height="24" Margin="3,0,0,4"
                        Command="{Binding StopRecordingCommand}" Style="{StaticResource ActionButton}"/>
                <Button Grid.Column="0" Grid.Row="1" Content="⏪ 재생" Height="24" Margin="0,0,3,0"
                        Command="{Binding PlaybackPathCommand}" Style="{StaticResource ActionButton}"/>
                <Button Grid.Column="1" Grid.Row="1" Content="🗑 경로 삭제" Height="24" Margin="3,0,0,0"
                        Command="{Binding ClearPathCommand}" Style="{StaticResource ActionButton}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
