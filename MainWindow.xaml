<Window x:Class="AquaVectorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AquaVectorUI.viewmodel"
        xmlns:views="clr-namespace:AquaVectorUI.views"
        Title="수중 무기 통제 시스템 (UWS-CTRL)"
        MinWidth="1100" MinHeight="700"
        Background="#0d1520">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="265" MinWidth="220"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*"   MinWidth="420"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="215" MinWidth="200"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT: COMM + LiDAR PPI + Log -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="2.2*" MinHeight="180"/>
                <RowDefinition Height="*"    MinHeight="100"/>
            </Grid.RowDefinitions>
            <views:CommPanel         Grid.Row="0"/>
            <views:LidarPpiControl   Grid.Row="1"/>
            <views:ReceiveLogControl Grid.Row="2"/>
        </Grid>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                      Background="#1e3050" ResizeBehavior="PreviousAndNext"/>

        <!-- CENTER: Global map -->
        <views:GlobalMapControl Grid.Column="2"/>

        <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                      Background="#1e3050" ResizeBehavior="PreviousAndNext"/>

        <!-- RIGHT: Control panels -->
        <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto">


            <StackPanel>
                <views:SystemStatusPanel/>
                <!-- <views:LaunchControlPanel/> -->
                <views:TorpedoFirePanel/>
                <views:PathControlPanel/>
            </StackPanel>
        </ScrollViewer>


    </Grid>
</Window>
